{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"],
    "paths": {
      "@auranote/core": ["../../packages/core/src/index.ts"]
    },
    "baseUrl": "."
  },
  "include": ["src/**/*.ts"]
}
